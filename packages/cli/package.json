{
  "name": "llm-switch",
  "version": "0.9.0",
  "description": "Switch LLM profiles for Claude Code, OpenCode, and other CLI tools",
  "type": "module",
  "bin": {
    "llm-switch": "bin/llm-switch.js",
    "sw": "bin/sw.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xavier2code/llm-switch.git"
  },
  "bugs": {
    "url": "https://github.com/xavier2code/llm-switch/issues"
  },
  "homepage": "https://github.com/xavier2code/llm-switch#readme",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "[ -d .git ] && git config core.hooksPath packages/cli/.githooks || true",
    "sync-plugin-version": "node scripts/sync-plugin-version.js",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build && pnpm sync-plugin-version"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^8.5.2",
    "@llm-switch/core": "workspace:*",
    "@llm-switch/tui": "workspace:*",
    "commander": "^15.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
