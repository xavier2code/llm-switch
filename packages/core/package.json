    "./adapters/anthropic-json-adapter.js": {
      "types": "./dist/adapters/anthropic-json-adapter.d.ts",
      "default": "./dist/adapters/anthropic-json-adapter.js"
    },
    "./adapters/openai-toml-adapter.js": {
      "types": "./dist/adapters/openai-toml-adapter.d.ts",
      "default": "./dist/adapters/openai-toml-adapter.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    },
    "./store/index.js": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    },
    "./store/profile-store.js": {
      "types": "./dist/store/profile-store.d.ts",
      "default": "./dist/store/profile-store.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "default": "./dist/state/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
