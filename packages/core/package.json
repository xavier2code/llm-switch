{
  "name": "@llm-switch/core",
  "version": "0.9.0",
  "type": "module",
  "description": "Core utilities for llm-switch - UI-agnostic configuration management",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.js": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./errors.js": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./migrate.js": {
      "types": "./dist/migrate.d.ts",
      "default": "./dist/migrate.js"
    },
    "./fs-utils.js": {
      "types": "./dist/fs-utils.d.ts",
      "default": "./dist/fs-utils.js"
    },
    "./providers.js": {
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    },
    "./validator.js": {
      "types": "./dist/validator.d.ts",
      "default": "./dist/validator.js"
    },
    "./detector.js": {
      "types": "./dist/detector.d.ts",
      "default": "./dist/detector.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./adapters/index.js": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./adapters/types.js": {
      "types": "./dist/adapters/types.d.ts",
      "default": "./dist/adapters/types.js"
    },
    "./adapters/base-adapter.js": {
      "types": "./dist/adapters/base-adapter.d.ts",
      "default": "./dist/adapters/base-adapter.js"
